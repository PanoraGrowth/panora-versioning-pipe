{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.4",
  "msteams": {
    "width": "Full"
  },
  "body": [
    {
      "type": "Container",
      "style": "$NOTIFICATION_STYLE",
      "bleed": true,
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "Image",
                  "url": "$NOTIFICATION_ICON",
                  "size": "Small"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "$NOTIFICATION_TITLE | Bitbucket-Pipeline",
                  "weight": "Bolder",
                  "size": "Large",
                  "wrap": true
                },
                {
                  "type": "TextBlock",
                  "text": "$NOTIFICATION_SUBTITLE",
                  "isSubtle": true,
                  "wrap": true
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "items": [
        {
          "type": "FactSet",
          "facts": [
            {
              "title": "🌿 Branch:",
              "value": "$BITBUCKET_BRANCH"
            },
            {
              "title": "🔀 PR:",
              "value": "#$BITBUCKET_PR_ID"
            },
            {
              "title": "🔖 Commit:",
              "value": "$BITBUCKET_COMMIT_SHORT"
            },
            {
              "title": "👤 Author:",
              "value": "$BITBUCKET_PR_AUTHOR"
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "🔍 View Pipeline",
      "url": "https://bitbucket.org/$BITBUCKET_WORKSPACE/$BITBUCKET_REPO_SLUG/pipelines/results/$BITBUCKET_BUILD_NUMBER"
    }
  ]
}
