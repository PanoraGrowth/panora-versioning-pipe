# Go integration test harness — environment variables
# Copy this file to .env.local and fill in values. Never commit .env.local.

# GitHub adapter (required for -platform github)
INTEGRATION_TEST_TOKEN=ghp_your_token_here

# Test repository override (optional — defaults to PanoraGrowth/panora-versioning-pipe-test)
TEST_REPO=PanoraGrowth/panora-versioning-pipe-test

# Run ID override (optional — defaults to random 8 hex chars)
# TEST_RUN_ID=

# Pipe preview image tag for workflow dispatch (optional)
# IMAGE_TAG=

# Bitbucket adapter (required for -platform bitbucket — T3)
# BB_TOKEN=
# BB_WORKSPACE=
# BB_REPO=

# Scenarios file path override (optional — defaults to tests/integration-go/scenarios/test-scenarios.yml)
# SCENARIOS_FILE=
